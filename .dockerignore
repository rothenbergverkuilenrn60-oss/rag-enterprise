# .dockerignore
# 排除不必要文件，加速构建上下文传输

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# 虚拟环境
.venv/
venv/
env/
.conda/

# 测试 & 覆盖率
.pytest_cache/
.coverage
htmlcov/
.tox/

# 本地数据（不打入镜像，运行时挂载卷）
data/
logs/
cache/
eval_reports/

# 模型文件（体积过大，通过 Ollama 拉取或卷挂载）
*.bin
*.pt
*.safetensors
*.gguf

# IDE & OS
.idea/
.vscode/
*.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# 文档
docs/
*.md

# 环境变量（安全）
.env
.env.docker
.env.local

# Docker 文件（避免递归）
Dockerfile*
docker-compose*.yml
docker/
