# =============================================================================
# .env.docker
# Docker Compose 环境变量 — 复制为 .env 并填写实际值
# =============================================================================

# ── 应用 ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── 安全 ──────────────────────────────────────────────────────────────────────
# 生产环境必须替换为 256 位随机字符串：
# openssl rand -hex 32
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-256BIT-KEY

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:14b

# OpenAI（可选，RAGAS judge model 推荐使用）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic（可选）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3

# ── VectorStore ───────────────────────────────────────────────────────────────
VECTOR_STORE=qdrant
QDRANT_COLLECTION=rag_enterprise_v3
QDRANT_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SEC=3600

# ── 检索参数 ──────────────────────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=6
HYDE_ENABLED=true
RERANKER_ENABLED=true

# ── 可观测性 ──────────────────────────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── RAGAS 评测 ────────────────────────────────────────────────────────────────
RAGAS_JUDGE_PROVIDER=openai
RAGAS_JUDGE_MODEL=gpt-4o
# RAGAS_JUDGE_API_KEY 自动读取 OPENAI_API_KEY
RAGAS_EVAL_DATASET=/app/eval/datasets/qa_pairs.json  # 200条企业制度QA
RAGAS_BATCH_SIZE=5
