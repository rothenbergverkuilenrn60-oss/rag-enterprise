{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "RAG Enterprise — API & Retrieval Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request Throughput & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean","max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(rag_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            {"color":"green","value":null}, {"color":"yellow","value":0.01}, {"color":"red","value":0.05}
          ]}
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "rate(rag_requests_total{status=~\"5..\"}[5m]) / rate(rag_requests_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "rag_cache_hits_total{result=\"hit\"}",
          "legendFormat": "Cache Hits",
          "refId": "A"
        },
        {
          "expr": "rag_cache_hits_total{result=\"miss\"}",
          "legendFormat": "Cache Misses",
          "refId": "B"
        }
      ],
      "title": "Cache Hits vs Misses",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "Retrieval Latency (P50 / P95 / P99)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean","p95"], "displayMode": "table" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "P50 total",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "P95 total",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "P99 total",
          "refId": "C"
        }
      ],
      "title": "End-to-End Retrieval Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_latency_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P95 {{stage}}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Stage (dense/sparse/rrf/rerank)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 102,
      "title": "LLM & Generation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_llm_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "P50 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_llm_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "P95 {{provider}}",
          "refId": "B"
        }
      ],
      "title": "LLM Response Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(rag_llm_tokens_estimated_total[5m])",
          "legendFormat": "Token/s ({{provider}})",
          "refId": "A"
        }
      ],
      "title": "Token Consumption Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Active Sessions & Rate Limiting",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            {"color":"green","value":null}, {"color":"yellow","value":50}, {"color":"red","value":100}
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 26 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "rag_active_requests",
          "legendFormat": "Active Requests",
          "refId": "A"
        }
      ],
      "title": "Active Requests",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 26 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(rag_rate_limit_hits_total[1m])",
          "legendFormat": "Rate Limited (req/s)",
          "refId": "A"
        }
      ],
      "title": "Rate Limit Rejections",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rag", "enterprise"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Enterprise Overview",
  "uid": "rag-enterprise-overview",
  "version": 1
}
