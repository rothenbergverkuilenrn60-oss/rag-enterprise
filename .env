# =============================================================================
# .env  —  本地开发环境配置
# ⚠️  此文件包含敏感信息，已加入 .gitignore，禁止提交到版本控制
# 生产环境通过 Docker Secrets 或 K8s Secrets 注入，不使用此文件
# =============================================================================

# ── 应用 ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── 安全 ──────────────────────────────────────────────────────────────────────
# 生产必须替换：openssl rand -hex 32
SECRET_KEY=CHANGE-ME-TO-256BIT-RANDOM-STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM Provider（三选一，取消注释对应块）────────────────────────────────────
# 方案一：本地 Ollama（推荐，数据不出本机）
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b

# 方案二：OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-4iCdubQNjXvC2grR3e3f5c1dEeA74d7a9f74983eEf5b9860
OPENAI_MODEL=gpt-4o

# 方案三：Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embedding ─────────────────────────────────────────────────────────────────
# 方案一：Ollama（与 LLM 共用同一服务）
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=bge-m3

# 方案二：本地 HuggingFace 模型（需要提前下载到 MODEL_DIR）
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL_PATH=/mnt/f/my_models/embedding_models/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# 方案三：OpenAI Embedding
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_enterprise_v3
QDRANT_API_KEY=
QDRANT_ON_DISK_PAYLOAD=true

# pgvector（已有 PostgreSQL 时可选）
# VECTOR_STORE=pgvector
# PG_DSN=postgresql+asyncpg://rag:rag@localhost:5432/ragdb

# Chroma（仅本地开发/PoC）
# VECTOR_STORE=chroma

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SEC=3600

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
RATE_LIMIT_RPM=60
REQUEST_TIMEOUT_SEC=120

# ── 文档预处理 ────────────────────────────────────────────────────────────────
PREPROCESS_CLEAN_HTML=true
PREPROCESS_REMOVE_HEADERS=true
PREPROCESS_DEDUPLICATE=true
PREPROCESS_LANGUAGE_DETECT=true
PREPROCESS_MIN_CHARS=50
PREPROCESS_MAX_CHARS=100000

# ── 文档提取 ──────────────────────────────────────────────────────────────────
EXTRACTOR_PDF_ENGINE=pymupdf
EXTRACTOR_OCR_ENABLED=false
EXTRACTOR_OCR_LANG=chi_sim+eng
EXTRACTOR_TABLE_EXTRACT=true
EXTRACTOR_MAX_WORKERS=4

# ── 分块策略 ──────────────────────────────────────────────────────────────────
# 可选：recursive | semantic | sentence | structure | parent_child | proposition
# 推荐企业制度文档使用 structure
CHUNK_STRATEGY=structure
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_MIN_SIZE=100
CHUNK_ADD_METADATA_HEADER=true
PARENT_CHUNK_SIZE=2048
SENTENCE_WINDOW_SIZE=3

# Contextual Retrieval（任意策略均可叠加，入库时调用 LLM 生成上下文说明）
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_RETRIEVAL_CONCURRENCY=3

# 父子块配置（CHUNK_STRATEGY=parent_child 时生效）
PARENT_CHILD_ENABLED=true
# QDRANT_PARENT_COLLECTION=rag_enterprise_v3_parent

# 命题化分块（CHUNK_STRATEGY=proposition 时生效，需要 LLM）
PROPOSITION_CONCURRENCY=3
PROPOSITION_MAX_RETRIES=2

# ── 检索参数 ──────────────────────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=6
RRF_K=60
HYDE_ENABLED=true
QUERY_REWRITE_ENABLED=true
MULTI_QUERY_COUNT=3

# Reranker
RERANKER_ENABLED=true
RERANKER_MODEL_PATH=/mnt/f/my_models/embedding_models/bge-m3-rerank
RERANKER_BATCH_SIZE=32

# ── LLM 生成参数 ──────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192
LLM_STREAM=true

# ── 可观测性（可选，生产环境推荐开启）────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=sk-lf-468d3a4b-a3d5-4261-ae4f-c44a5d67660d
LANGFUSE_PUBLIC_KEY=pk-lf-a0bb801a-18d3-44e5-a93e-b9ab5f3fc724
LANGFUSE_BASE_URL=https://cloud.langfuse.com

OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

# ── NLU ───────────────────────────────────────────────────────────────────────
# true = 意图/实体识别用 LLM 深度解析（慢但准）
# false = 仅用规则引擎（快，适合开发调试）
NLU_LLM_ENABLED=true

# ── 记忆系统 ──────────────────────────────────────────────────────────────────
SESSION_TTL_SEC=7200
# 长期记忆使用 PG_DSN 中配置的 PostgreSQL

# ── 事件总线 / Kafka ──────────────────────────────────────────────────────────
# 空 = 进程内内存总线（开发/单机）
# 填写 = 启用 Kafka（生产多实例部署）
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_PREFIX=rag

# ── 知识库自动更新 ────────────────────────────────────────────────────────────
AUTO_UPDATE_ON_STARTUP=false
AUTO_UPDATE_INTERVAL_SEC=0
